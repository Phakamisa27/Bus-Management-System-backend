# Copy this file to `.env` and fill in real values. The `.env` file is
# gitignored, so secrets stay out of version control.

DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/bus_tracking_db
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Email (SMTP) settings ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=myemail@gmail.com
# IMPORTANT: Use a Gmail "App Password" (16 chars), NOT your normal Gmail
# password. Generate it at: Google Account -> Security -> App passwords.
# Never commit the real value.
SMTP_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=myemail@gmail.com
# Base URL of the frontend; used to build the reset link.
FRONTEND_URL=http://localhost:5500
